---
import PercentageCalculator from '../components/PercentageCalculator.jsx';
import StackInfo from '../components/StackInfo.jsx';
import '../styles.css'

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const socialImageUrl = new URL("/site.png", Astro.site).toString();
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="icon" href="/favicon.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<meta name="generator" content={Astro.generator} />
		<title>Percento</title>
		<link rel="canonical" href={canonicalUrl} />
		<meta name="description" content="Fast percentage calculator: percent of a number, percentage change, percentage difference, and more." />
		<meta name="robots" content="index,follow" />
		<meta name="theme-color" content="#0f172a" />
		<meta name="color-scheme" content="dark light" />
		<meta property="og:title" content="Percento" />
		<meta property="og:description" content="Fast percentage calculator: percent of a number, percentage change, percentage difference, and more." />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={socialImageUrl} />
		<meta property="og:image:alt" content="Percento — quick percentage tools" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="Percento" />
		<meta name="twitter:description" content="Fast percentage calculator: percent of a number, percentage change, percentage difference, and more." />
		<meta name="twitter:url" content={canonicalUrl} />
		<meta name="twitter:image" content={socialImageUrl} />
		<meta name="twitter:image:alt" content="Percento — quick percentage tools" />
	</head>
	<body class="h-dvh grid place-items-center p-4 bg-animation">
		
		<main>
			<PercentageCalculator client:load />
			<StackInfo client:load />
		</main>
	</body>
</html>
